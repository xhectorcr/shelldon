{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../src",
    "distDir": "../src",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "ShellDon",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true,
        "execute": true,
        "sidecar": false,
        "scope": [
          { "name": "wt",          "cmd": "wt.exe",          "args": true },
          { "name": "powershell",  "cmd": "powershell.exe",  "args": true },
          { "name": "cmd",         "cmd": "cmd.exe",         "args": true }
        ]
      },
      "dialog": {
        "all": false,
        "open": true
      },
      "fs": {
        "all": false,
        "readFile":  true,
        "writeFile": true,
        "createDir": true,
        "scope": ["$APPDATA/*", "$HOME/.shelldon/*"]
      },
      "path": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.shelldon.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "title":      "ShellDon",
        "width":      1100,
        "height":     700,
        "minWidth":   800,
        "minHeight":  550,
        "center":     true,
        "resizable":  true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "theme": "Dark"
      }
    ]
  }
}
